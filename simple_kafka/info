-- CREATE TOPIC 
CREATE STREAM IF NOT EXISTS STREAM_T1_T2 WITH (KAFKA_TOPIC='T1_T2', PARTITIONS=1, REPLICAS=1, VALUE_FORMAT='AVRO') 
AS SELECT 
    T1.id ROWKEY, --es la KEY
    T2.id as id,
    T1.name as name,
    T2.value as value
    FROM STREAM_T2 T2
    INNER JOIN  STREAM_T1 T1 WITHIN 3 DAYS
    ON T2.id = T1.id;
NOTA: Si le das el T1.id ROWKEY, de las el valor al key

SELECT * FROM STREAM_T1_T2 EMIT CHANGES;


--- JOIN 3 STREAMS
SELECT 
    T1.id,
    T2.id as id,
    T1.name as name,
    T2.value as value,
    T3.other_value as other_value
    FROM STREAM_T2 T2
    INNER JOIN  STREAM_T1 T1 WITHIN 3 DAYS
    ON T2.id = T1.id
    INNER JOIN  STREAM_T3 T3 WITHIN 3 DAYS
    ON T2.id = T3.id
EMIT CHANGES;
-- create topic
CREATE STREAM IF NOT EXISTS STREAM_T1_T2_T3 WITH (KAFKA_TOPIC='T1_T2_T3', PARTITIONS=1, REPLICAS=1, VALUE_FORMAT='AVRO') 
AS SELECT
    T1.id ROWKEY, --es la KEY
    T2.id as id,
    T1.name as name,
    T2.value as value,
    T3.other_value as other_value
    FROM STREAM_T2 T2
    INNER JOIN  STREAM_T1 T1 WITHIN 3 DAYS
    ON T2.id = T1.id
    INNER JOIN  STREAM_T3 T3 WITHIN 3 DAYS
    ON T2.id = T3.id;

